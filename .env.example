# Copy this file to .env and fill in your values.
# .env is gitignored and will be auto-loaded by the server and agent.

# Shared secret between server and agent (required)
CLAUDE_DASHBOARD_API_KEY=change-me-to-a-secret

# Server settings (optional — defaults shown)
# CLAUDE_DASHBOARD_HOST=0.0.0.0
# CLAUDE_DASHBOARD_PORT=5050
# CLAUDE_DASHBOARD_DB_PATH=./sessions.db

# Agent settings (optional)
# CLAUDE_DASHBOARD_SERVER_URL=http://localhost:5050
# CLAUDE_DASHBOARD_VM_NAME=my-machine

# Cloudflare Access service token (optional — only if server is behind Cloudflare Access)
# CF_ACCESS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.access
# CF_ACCESS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
